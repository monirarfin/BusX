rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'role']);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role'])
             && data.uid == request.auth.uid
             && data.email is string && data.email.size() > 0
             && data.role in ['customer', 'driver'];
    }

    // --- Deliveries Collection ---
    match /deliveries/{deliveryId} {
      allow get: if isSignedIn() && (
        ( 'senderId' in existing() && isOwner(existing().senderId) ) || 
        ( 'driverId' in existing() && isOwner(existing().driverId) ) ||
        ( 'status' in existing() && existing().status == 'pending' )
      );

      allow list: if isSignedIn() && (
        ( 'senderId' in resource.data && resource.data.senderId == request.auth.uid ) ||
        ( 'driverId' in resource.data && resource.data.driverId == request.auth.uid ) ||
        ( 'status' in resource.data && resource.data.status in ['pending', 'at_hub'] )
      );
      
      allow create: if isVerified() && isValidDelivery(incoming()) 
                    && isOwner(incoming().senderId);
                    
      allow update: if isVerified() && (
        // Action: Cancel (Sender only if pending)
        (isOwner(existing().senderId) && existing().status == 'pending' && incoming().status == 'cancelled' 
         && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        
        // Action: Accept (Driver only if pending or at_hub)
        (existing().status in ['pending', 'at_hub'] && incoming().status == 'accepted' 
         && incoming().driverId == request.auth.uid
         && (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'driverId', 'updatedAt']) || 
             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'driverId', 'updatedAt', 'currentHubId']))) ||
         
        // Action: Update Status (Assigned Driver only)
        (isOwner(existing().driverId) && incoming().status in ['picked_up', 'in_transit', 'delivered']
         && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||

        // Action: Handover to Hub (Assigned Driver only)
        (isOwner(existing().driverId) && incoming().status == 'at_hub'
         && incoming().driverId == null
         && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'driverId', 'currentHubId', 'updatedAt']))
      );
    }

    function isValidDelivery(data) {
      return data.keys().hasAll(['senderId', 'pickup', 'dropoff', 'status'])
             && data.senderId is string
             && data.status in ['pending', 'accepted', 'picked_up', 'in_transit', 'delivered', 'cancelled', 'at_hub']
             && data.pickup.lat is number && data.pickup.lng is number
             && data.dropoff.lat is number && data.dropoff.lng is number;
    }

    // --- Messages Subcollection ---
    match /deliveries/{deliveryId}/messages/{messageId} {
      allow read: if isSignedIn() && (
        isOwner(get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.senderId) ||
        isOwner(get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.driverId)
      );
      
      allow create: if isSignedIn() && (
        isOwner(get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.senderId) ||
        isOwner(get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.driverId)
      ) && isValidMessage(incoming());
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'timestamp'])
             && data.senderId == request.auth.uid
             && data.text is string && data.text.size() > 0 && data.text.size() <= 1000;
    }

    // --- Bus Counters ---
    match /bus_counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if isVerified() && isValidBusCounter(incoming());
    }

    function isValidBusCounter(data) {
      return data.keys().hasAll(['name', 'companyName', 'location'])
             && data.name is string && data.name.size() > 0
             && data.companyName is string && data.companyName.size() > 0
             && data.location.lat is number && data.location.lng is number;
    }

    // --- Bus Transports ---
    match /bus_transports/{transportId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidBusTransport(incoming());
      allow update: if isSignedIn() && (
        (isOwner(existing().driverId) && isVerified() && isValidBusTransport(incoming())) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['slots'])) // Support booking
      );
    }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    function isValidBusTransport(data) {
      return data.keys().hasAll(['busNumber', 'companyName', 'route', 'driverId'])
             && data.busNumber is string && data.busNumber.size() > 0
             && data.companyName is string && data.companyName.size() > 0
             && data.route is string && data.route.size() > 0
             && data.driverId == request.auth.uid;
    }
  }
}
